#include <MPU6050.h>
#include <Wire.h>

MPU6050 mpu;
const int LED_PIN = 2, BUZZER_PIN = 5, VIBRATION_SWITCH_PIN = 4;
const float LOW_THRESHOLD = 15.0, HIGH_THRESHOLD = 25.0;
float accel_x_filtered = 0, accel_y_filtered = 0, accel_z_filtered = 0;
const float ALPHA = 0.2;
bool led_blinking = false, buzzer_active = false;
unsigned long last_led_toggle = 0, last_check = 0;

void setup() {
  Serial.begin(115200);
  Wire.begin(21, 22);
  pinMode(LED_PIN, OUTPUT);
  pinMode(BUZZER_PIN, OUTPUT);
  pinMode(VIBRATION_SWITCH_PIN, INPUT);
  digitalWrite(LED_PIN, LOW);
  digitalWrite(BUZZER_PIN, LOW);
  
  if (!mpu.begin(MPU6050_SCALE_2000DPS, MPU6050_RANGE_16G)) {
    Serial.println("MPU6050 not found!");
    while (1);
  }
  Serial.println("MPU6050 initialized");
}

void loop() {
  unsigned long now = millis();
  Vector accel = mpu.readRawAccel();
  
  accel_x_filtered = ALPHA * (accel_x_filtered + accel.XAxis);
  accel_y_filtered = ALPHA * (accel_y_filtered + accel.YAxis);
  accel_z_filtered = ALPHA * (accel_z_filtered + accel.ZAxis - 9.81);
  
  float magnitude = sqrt(accel_x_filtered*accel_x_filtered + 
                        accel_y_filtered*accel_y_filtered + 
                        accel_z_filtered*accel_z_filtered);
  
  bool vibration_detected = (digitalRead(VIBRATION_SWITCH_PIN) == LOW);
  
  if (magnitude >= HIGH_THRESHOLD || vibration_detected) {
    led_blinking = true;
    buzzer_active = true;
  } 
  else if (magnitude >= LOW_THRESHOLD) {
    led_blinking = true;
    buzzer_active = false;
  } 
  else {
    led_blinking = false;
    buzzer_active = false;
  }
  
  if (led_blinking) {
    if (now - last_led_toggle > 500) {
      digitalWrite(LED_PIN, !digitalRead(LED_PIN));
      last_led_toggle = now;
    }
  } else {
    digitalWrite(LED_PIN, LOW);
  }
  
  if (buzzer_active) {
    static unsigned long buzz_start = 0;
    if (buzz_start == 0) buzz_start = now;
    unsigned long buzz_age = (now - buzz_start) % 1000;
    int freq = 800 + (buzz_age / 2);
    if (buzz_age > 500) freq = 1300 - ((buzz_age - 500) / 2);
    tone(BUZZER_PIN, freq, 10);
  } else {
    noTone(BUZZER_PIN);
  }
  
  if (now - last_check > 200) {
    Serial.print("Accel: ");
    Serial.print(magnitude, 2);
    Serial.print(" m/s^2 | LED: ");
    Serial.print(led_blinking ? "ON" : "OFF");
    Serial.print(" | Buzzer: ");
    Serial.println(buzzer_active ? "ON" : "OFF");
    last_check = now;
  }
}
